### register user
POST http://localhost:5000/api/auth/register
Content-Type: application/json

{
  "name": "Lucky",
  "email": "lucky@gmail.com",
  "password": "lucky123"
}

### login user
POST http://localhost:5000/api/auth/login
Content-Type: application/json

{
  "email": "lucky@gmail.com",
  "password": "lucky123"
}

### get users
GET http://localhost:5000/api/users

### create room (requires Bearer token)
POST http://localhost:5000/api/rooms/create
Content-Type: application/json
Authorization: Bearer your_jwt_token_here

{
  "roomName": "DSA Practice Group",
  "language": "javascript",
  "visibility": "private"
}

### get room by id
GET http://localhost:5000/api/rooms/ABC123

### leave room (requires Bearer token)
POST http://localhost:5000/api/rooms/leave/ABC123
Content-Type: application/json
Authorization: Bearer your_jwt_token_here

{
  "userId": "user-id"
}

### get room messages
GET http://localhost:5000/api/messages/ABC123

### send message (REST fallback)
POST http://localhost:5000/api/messages/send
Content-Type: application/json
Authorization: Bearer your_jwt_token_here

{
  "roomId": "ABC123",
  "senderId": "user-id",
  "senderName": "Lucky",
  "text": "Hi team"
}

### execute code
POST http://localhost:5000/api/code/execute
Content-Type: application/json

{
  "language": "python",
  "code": "print('Hello World')"
}
